{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAHP Swarm Run",
  "type": "object",
  "required": ["run_id", "repo", "started_at", "mode", "result", "roles_executed"],
  "properties": {
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "title": {
      "type": "string",
      "minLength": 12,
      "maxLength": 160,
      "description": "Readable, explicit run title"
    },
    "incident_id": {
      "type": "string",
      "pattern": "^INC-[0-9]{8}-[0-9]{3,}$"
    },
    "incident_title": {
      "type": "string",
      "minLength": 20,
      "maxLength": 180
    },
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "mode": {
      "type": "string",
      "enum": ["review", "dev", "release", "incident"]
    },
    "result": {
      "type": "string",
      "enum": ["pass", "warning", "fail", "block"]
    },
    "roles_executed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "finding.schema.json"}
    },
    "verified": {
      "type": "array",
      "items": {"type": "string"}
    },
    "assumed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}

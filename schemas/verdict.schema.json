{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAHP Swarm Verdict",
  "type": "object",
  "required": ["role", "result", "blocking", "safe_to_commit"],
  "properties": {
    "role": {"type": "string", "const": "verdict"},
    "result": {
      "type": "string",
      "enum": ["pass", "warning", "fail", "block"]
    },
    "blocking": {"type": "boolean"},
    "reason": {"type": "string"},
    "required_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_followups": {
      "type": "array",
      "items": {"type": "string"}
    },
    "safe_to_commit": {"type": "boolean"}
  },
  "additionalProperties": true
}
